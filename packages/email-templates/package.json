{
  "name": "@haulbot/email-templates",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "description": "Haulbot transactional email templates (React Email)",
  "exports": {
    ".": "./src/index.ts",
    "./send": "./src/fill-magic-link.ts"
