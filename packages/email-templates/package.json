    "@react-email/render": "^2.0.10",
    "react": "^19.2.7",
    "react-dom": "^19.2.7"
  },
  "devDependencies": {
    "@react-email/ui": "^6.6.6",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "react-email": "^6.6.6"
  }
}
