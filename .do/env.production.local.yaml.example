# Copy to env.production.local.yaml (gitignored) and fill before first deploy.
# Paste these values into DigitalOcean → Apps → haulbot → Settings → Environment Variables
# with the Encrypt toggle ON for every secret below.
#
# Generate strong tokens:
#   openssl rand -hex 32

secrets:
  # Required — backend refuses production without these
  SESSION_SECRET: ""
  DISPATCHER_SERVICE_TOKEN: ""
  EXTENSION_SERVICE_TOKEN: ""
  TELEGRAM_BOT_TOKEN: ""
  TELEGRAM_WEBHOOK_SECRET: ""
  STRIPE_SECRET_KEY: ""
  STRIPE_WEBHOOK_SECRET: ""
  STRIPE_PRICE_ID: ""
  STRIPE_PUBLISHABLE_KEY: ""
  RESEND_API_KEY: ""
  ADMIN_TOKEN: ""

  # Relay credential vault — required in production (backend rejects dev stub)
  VAULT_ADDR: ""
  VAULT_TOKEN: ""

  # Optional — enable when ready
  ANALYTICS_ENGINE_URL: ""
  ANALYTICS_ENGINE_TOKEN: ""
  BRIEFING_ENABLED: ""
  PROVISIONER: "" # set to "aws" for WorkSpaces Secure Browser
  WSW_BROWSER_SETTINGS_ARN: ""
  WSW_NETWORK_SETTINGS_ARN: ""
  WSW_USER_SETTINGS_ARN: ""

# Override if not using the attached DO MongoDB component or need /haulbot db suffix:
# MONGODB_URI: "mongodb+srv://..."
