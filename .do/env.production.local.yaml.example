# Copy to env.production.local.yaml (gitignored) and fill every value before deploy.
# Then: python3 scripts/build-do-deploy-spec.py
#       doctl apps update <app-id> --spec .do/app.deploy.yaml --wait

secrets:
  SESSION_SECRET: ""
  ADMIN_TOKEN: ""
  DISPATCHER_SERVICE_TOKEN: ""
  EXTENSION_SERVICE_TOKEN: ""
  TELEGRAM_BOT_TOKEN: ""
  TELEGRAM_WEBHOOK_SECRET: ""
  STRIPE_SECRET_KEY: ""
  STRIPE_PUBLISHABLE_KEY: ""
  STRIPE_WEBHOOK_SECRET: ""
  STRIPE_PRICE_ID: ""
  RESEND_API_KEY: ""
  MONGODB_URI: ""
  BRIEFING_ENABLED: "false"
  ANALYTICS_ENGINE_URL: "disabled"
  ANALYTICS_ENGINE_TOKEN: "disabled"
  GA4_API_SECRET: ""
  VAULT_ADDR: "disabled"
  VAULT_TOKEN: "disabled"
  PROVISIONER: "stub"
  WSW_BROWSER_SETTINGS_ARN: "disabled"
  WSW_NETWORK_SETTINGS_ARN: "disabled"
  WSW_USER_SETTINGS_ARN: "disabled"
