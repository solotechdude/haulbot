{
  "name": "haulbot",
  "private": true,
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "db:up": "docker compose up -d",
    "db:down": "docker compose down",
    "db:migrate": "bash scripts/migrate-db-to-haulbot.sh",
    "db:logs": "docker compose logs -f mongodb",
    "dev:backend": "bun run --filter @haulbot/backend dev",
    "dev:website": "bun run --filter @haulbot/website dev",
    "dev:email": "bun run --filter @haulbot/email-templates dev",
    "export:email": "bun run --filter @haulbot/email-templates export:magic-link",
    "dev:bot": "bun run --filter @haulbot/bot dev",
    "dev:remotion": "bun run --filter @haulbot/remotion studio",
    "render:hero": "bun run --filter @haulbot/remotion render:hero",
    "dev:bot:once": "bun run --filter @haulbot/bot start",
    "bot:stop": "pkill -f 'haulbot/apps/bot' 2>/dev/null || true; pkill -f '@haulbot/bot' 2>/dev/null || true",
    "dev": "bun run dev:backend & bun run dev:website",
    "seed:dev": "bun run --filter @haulbot/backend seed:dev",
    "seed:user": "bun run --filter @haulbot/backend seed:user",
    "set:campaign": "bun run --filter @haulbot/backend set:campaign",
    "fix:booking-route": "bun run --filter @haulbot/backend fix:booking-route",
    "reconcile:stripe": "bun run --filter @haulbot/backend reconcile:stripe",
    "stripe:listen": "bash scripts/stripe-listen.sh",
    "typecheck": "bun run --filter '*' typecheck",
    "audit:fallow": "fallow audit --base main --gate new-only --format json --quiet || true"
  },
  "devDependencies": {
    "@types/bun": "^1.2.2",
    "typescript": "^5.7.3"
  }
}
