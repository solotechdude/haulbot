{
  "$schema": "https://raw.githubusercontent.com/fallow-rs/fallow/main/schema.json",
  "ignorePatterns": ["**/dist/**", "**/node_modules/**", "**/.next/**"],
  "rules": {
    "unused-files": "warn",
    "unused-exports": "warn",
    "unused-types": "warn",
    "duplicate-exports": "error",
    "boundary-violations": "error",
    "circular-deps": "error"
  },
  "boundaries": {
    "zones": [
      { "name": "shared", "patterns": ["packages/shared/**"] },
      { "name": "website", "patterns": ["apps/website/**"] },
      { "name": "backend", "patterns": ["apps/backend/**"] },
      { "name": "bot", "patterns": ["apps/bot/**"] }
    ],
    "rules": [
      { "from": "website", "allow": ["shared"] },
      { "from": "backend", "allow": ["shared"] },
      { "from": "bot", "allow": ["shared"] },
      { "from": "shared", "allow": [] }
    ]
  }
}
