# Backend
PORT=8080
# Dedicated Docker MongoDB (docker compose up -d) — port 27019, database haulbot
MONGODB_URI=mongodb://127.0.0.1:27019/haulbot
DISPATCHER_SERVICE_TOKEN=dev-dispatcher-token
# Extension → dispatcher API auth. Unset = migration window (token check skipped).
EXTENSION_SERVICE_TOKEN=
# HMAC secret for /solo session tokens — required in production
SESSION_SECRET=
# Product Admin token for /admin (fails closed when unset)
ADMIN_TOKEN=
# Comma-separated browser origins allowed by CORS (defaults to WEBSITE_URL)
CORS_ORIGINS=

# Website (BFF proxy target)
VITE_API_ORIGIN=http://localhost:8080
VITE_STRIPE_PUBLISHABLE_KEY=
VITE_TELEGRAM_BOT_USERNAME=agent_haulbot
# Google Analytics 4 measurement ID (G-XXXXXXXXXX). Website app injects gtag — do not paste the HTML snippet into index.html. Production builds only (skipped in vite dev).
VITE_GA_MEASUREMENT_ID=

# Bot
SOLO_API_ORIGIN=http://localhost:8080
TELEGRAM_BOT_TOKEN=
TELEGRAM_BOT_USERNAME=agent_haulbot
# Production webhook mode — unset = long polling (dev). Path is taken from the URL.
TELEGRAM_WEBHOOK_URL=
TELEGRAM_WEBHOOK_SECRET=
BOT_PORT=8081
# HTTPS URL for Start search Mini App (Telegram requires HTTPS). Unset + HTTP WEBSITE_URL = plain text button in dev.
# Example: cloudflared tunnel --url http://localhost:3000 → paste https://….trycloudflare.com/telegram/location.html
TELEGRAM_MINI_APP_URL=
# Set true locally to test /2fa flow after /connect_relay
RELAY_REQUIRE_2FA=false

# Stripe — use `bun run stripe:listen` locally; paste whsec_ into STRIPE_WEBHOOK_SECRET
STRIPE_SECRET_KEY=
STRIPE_PUBLISHABLE_KEY=
STRIPE_WEBHOOK_SECRET=
STRIPE_PRICE_ID=
# Public site URL — also serves Telegram Start search Mini App at /telegram/location.html
WEBSITE_URL=http://localhost:3000

# Production deploy: see .do/app.yaml and .do/env.production.yaml (DigitalOcean App Platform)

# Resend
RESEND_API_KEY=
EMAIL_FROM=

# Load Analytics Engine (external location-analytics backend)
ANALYTICS_ENGINE_URL=
ANALYTICS_ENGINE_TOKEN=
# Morning briefing hour (UTC). Loop auto-enables when the engine is configured.
BRIEFING_UTC_HOUR=12
BRIEFING_ENABLED=

# HashiCorp Vault (KV v2) — Relay credentials. Unset = dev stub (local only);
# production refuses to store credentials without Vault.
VAULT_ADDR=
VAULT_TOKEN=
VAULT_KV_MOUNT=secret

# Dedicated Environment provisioning — "aws" = WorkSpaces Secure Browser, else dev stub
PROVISIONER=
AWS_REGION=us-east-1
WSW_BROWSER_SETTINGS_ARN=
WSW_NETWORK_SETTINGS_ARN=
WSW_USER_SETTINGS_ARN=
