# Backend
PORT=8080
# Dedicated Docker MongoDB (docker compose up -d) — port 27019, database relaybooking_solo
MONGODB_URI=mongodb://127.0.0.1:27019/relaybooking_solo
DISPATCHER_SERVICE_TOKEN=dev-dispatcher-token
# Extension → dispatcher API auth. Unset = migration window (token check skipped).
EXTENSION_SERVICE_TOKEN=
# HMAC secret for /solo session tokens — required in production
SESSION_SECRET=

# Website (BFF proxy target)
VITE_API_ORIGIN=http://localhost:8080
VITE_STRIPE_PUBLISHABLE_KEY=

# Bot
SOLO_API_ORIGIN=http://localhost:8080
TELEGRAM_BOT_TOKEN=
TELEGRAM_BOT_USERNAME=SwiftRelaySoloBot
# Set true locally to test /2fa flow after /connect_relay
RELAY_REQUIRE_2FA=false

# Stripe — use `bun run stripe:listen` locally; paste whsec_ into STRIPE_WEBHOOK_SECRET
STRIPE_SECRET_KEY=
STRIPE_PUBLISHABLE_KEY=
STRIPE_WEBHOOK_SECRET=
STRIPE_PRICE_ID=
WEBSITE_URL=http://localhost:3000

# Resend
RESEND_API_KEY=

# Load Analytics Engine (external location-analytics backend)
ANALYTICS_ENGINE_URL=
ANALYTICS_ENGINE_TOKEN=
