{
  "name": "@haulbot/remotion",
  "version": "0.0.1",
  "private": true,
  "type": "module",
  "scripts": {
    "studio": "remotion studio",
    "render:hero": "bun run render:hero:webm && bun run render:hero:mp4 && bun run still:hero",
    "render:hero:webm": "remotion render src/index.ts HeroCampaignDemo ../website/public/videos/hero-campaign-demo.webm --codec=vp9",
    "render:hero:mp4": "remotion render src/index.ts HeroCampaignDemo ../website/public/videos/hero-campaign-demo.mp4 --codec=h264",
    "still:hero": "remotion still src/index.ts HeroCampaignDemo ../website/public/videos/hero-campaign-demo-poster.png --frame=15",
    "typecheck": "tsc -p tsconfig.json --noEmit"
  },
  "dependencies": {
    "@haulbot/shared": "workspace:*",
    "@remotion/cli": "4.0.286",
    "@remotion/google-fonts": "4.0.286",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "remotion": "4.0.286"
  },
  "devDependencies": {
    "@types/react": "^19.0.8",
    "typescript": "^5.7.3"
  }
}
